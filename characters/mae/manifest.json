{
  "name": "Mae",
  "svg": "puppet.svg",
  "height": 560,
  "voice": {
    "engine": "say",
    "voice": "Karen"
  },
  "mouths": {
    "A": "#mouth-A",
    "B": "#mouth-B",
    "C": "#mouth-C",
    "D": "#mouth-D",
    "E": "#mouth-E",
    "F": "#mouth-F",
    "G": "#mouth-G",
    "H": "#mouth-H",
    "X": "#mouth-X"
  },
  "restMouth": "X",
  "blink": {
    "target": "#eyes"
  },
  "look": {
    "target": "#pupils",
    "dx": 4,
    "dy": 2
  },
  "walk": {
    "speed": 200,
    "bob": true
  },
  "views": {
    "face": {
      "focus": "#head",
      "fill": 0.6,
      "centerY": 0.47
    }
  },
  "idle": {
    "breathe": {
      "target": "#body",
      "amount": 1.3,
      "period": 4200
    },
    "gaze": true
  },
  "actions": {
    "wave": {
      "tracks": [
        {
          "target": "#arm-right",
          "duration": 1300,
          "keyframes": [
            { "transform": "rotate(0deg)" },
            { "transform": "rotate(-175deg)", "offset": 0.15 },
            { "transform": "rotate(-95deg)", "offset": 0.4 },
            { "transform": "rotate(-175deg)", "offset": 0.65 },
            { "transform": "rotate(-95deg)", "offset": 0.9 },
            { "transform": "rotate(0deg)" }
          ]
        },
        {
          "target": "#body",
          "duration": 1300,
          "keyframes": [
            { "transform": "rotate(0deg)" },
            { "transform": "rotate(3deg)", "offset": 0.15 },
            { "transform": "rotate(-3deg)", "offset": 0.4 },
            { "transform": "rotate(3deg)", "offset": 0.65 },
            { "transform": "rotate(-3deg)", "offset": 0.9 },
            { "transform": "rotate(0deg)" }
          ]
        },
        {
          "target": "#head",
          "duration": 1300,
          "keyframes": [
            { "transform": "rotate(0deg)" },
            { "transform": "rotate(-6deg)", "offset": 0.15 },
            { "transform": "rotate(4deg)", "offset": 0.4 },
            { "transform": "rotate(-6deg)", "offset": 0.65 },
            { "transform": "rotate(4deg)", "offset": 0.9 },
            { "transform": "rotate(0deg)" }
          ]
        }
      ]
    },
    "nod": {
      "tracks": [
        {
          "target": "#head",
          "duration": 1200,
          "keyframes": [
            { "transform": "translateY(0) rotate(0deg)" },
            { "transform": "translateY(20px) rotate(11deg)", "offset": 0.15 },
            { "transform": "translateY(-6px) rotate(-6deg)", "offset": 0.4 },
            { "transform": "translateY(20px) rotate(11deg)", "offset": 0.65 },
            { "transform": "translateY(-6px) rotate(-6deg)", "offset": 0.9 },
            { "transform": "translateY(0) rotate(0deg)" }
          ]
        },
        {
          "target": "#body",
          "duration": 1200,
          "keyframes": [
            { "transform": "translateY(0)" },
            { "transform": "translateY(-3px)", "offset": 0.15 },
            { "transform": "translateY(1px)", "offset": 0.4 },
            { "transform": "translateY(-3px)", "offset": 0.65 },
            { "transform": "translateY(1px)", "offset": 0.9 },
            { "transform": "translateY(0)" }
          ]
        }
      ]
    },
    "shake": {
      "tracks": [
        {
          "target": "#head",
          "duration": 1200,
          "keyframes": [
            { "transform": "translateX(0) rotate(0deg)" },
            { "transform": "translateX(-18px) rotate(-12deg)", "offset": 0.15 },
            { "transform": "translateX(18px) rotate(12deg)", "offset": 0.4 },
            { "transform": "translateX(-18px) rotate(-12deg)", "offset": 0.65 },
            { "transform": "translateX(18px) rotate(12deg)", "offset": 0.9 },
            { "transform": "translateX(0) rotate(0deg)" }
          ]
        },
        {
          "target": "#body",
          "duration": 1200,
          "keyframes": [
            { "transform": "rotate(0deg)" },
            { "transform": "rotate(4deg)", "offset": 0.15 },
            { "transform": "rotate(-4deg)", "offset": 0.4 },
            { "transform": "rotate(4deg)", "offset": 0.65 },
            { "transform": "rotate(-4deg)", "offset": 0.9 },
            { "transform": "rotate(0deg)" }
          ]
        }
      ]
    },
    "curtsy": {
      "tracks": [
        {
          "target": "#puppet",
          "duration": 1500,
          "easing": "ease-in-out",
          "keyframes": [
            { "transform": "translateY(0)" },
            { "transform": "translateY(18px)", "offset": 0.35 },
            { "transform": "translateY(18px)", "offset": 0.7 },
            { "transform": "translateY(0)" }
          ]
        },
        {
          "target": "#head",
          "duration": 1500,
          "easing": "ease-in-out",
          "keyframes": [
            { "transform": "translateY(0) rotate(0deg)" },
            { "transform": "translateY(8px) rotate(16deg)", "offset": 0.35 },
            { "transform": "translateY(8px) rotate(16deg)", "offset": 0.7 },
            { "transform": "translateY(0) rotate(0deg)" }
          ]
        },
        {
          "target": "#body",
          "duration": 1500,
          "easing": "ease-in-out",
          "keyframes": [
            { "transform": "scale(1,1)" },
            { "transform": "scale(1.14,0.86)", "offset": 0.35 },
            { "transform": "scale(1.14,0.86)", "offset": 0.7 },
            { "transform": "scale(1,1)" }
          ]
        },
        {
          "target": "#leg-left",
          "duration": 1500,
          "easing": "ease-in-out",
          "keyframes": [
            { "transform": "rotate(0deg)" },
            { "transform": "rotate(8deg)", "offset": 0.35 },
            { "transform": "rotate(8deg)", "offset": 0.7 },
            { "transform": "rotate(0deg)" }
          ]
        },
        {
          "target": "#leg-right",
          "duration": 1500,
          "easing": "ease-in-out",
          "keyframes": [
            { "transform": "rotate(0deg)" },
            { "transform": "rotate(-8deg)", "offset": 0.35 },
            { "transform": "rotate(-8deg)", "offset": 0.7 },
            { "transform": "rotate(0deg)" }
          ]
        }
      ]
    },
    "happy": {
      "hold": true,
      "tracks": [
        { "target": "#brow-left", "duration": 300, "fill": "forwards",
          "keyframes": [{ "transform": "translateY(0)" }, { "transform": "translateY(-4px)" }] },
        { "target": "#brow-right", "duration": 300, "fill": "forwards",
          "keyframes": [{ "transform": "translateY(0)" }, { "transform": "translateY(-4px)" }] },
        { "target": "#cheek-left", "duration": 300, "fill": "forwards",
          "keyframes": [{ "opacity": 0.4 }, { "opacity": 0.9 }] },
        { "target": "#cheek-right", "duration": 300, "fill": "forwards",
          "keyframes": [{ "opacity": 0.4 }, { "opacity": 0.9 }] }
      ]
    },
    "sad": {
      "hold": true,
      "tracks": [
        { "target": "#brow-left", "duration": 300, "fill": "forwards",
          "keyframes": [{ "transform": "rotate(0deg) translateY(0)" }, { "transform": "rotate(12deg) translateY(3px)" }] },
        { "target": "#brow-right", "duration": 300, "fill": "forwards",
          "keyframes": [{ "transform": "rotate(0deg) translateY(0)" }, { "transform": "rotate(-12deg) translateY(3px)" }] },
        { "target": "#head", "duration": 300, "fill": "forwards",
          "keyframes": [{ "transform": "translateY(0)" }, { "transform": "translateY(6px)" }] }
      ]
    },
    "surprised": {
      "hold": true,
      "tracks": [
        { "target": "#brow-left", "duration": 250, "fill": "forwards",
          "keyframes": [{ "transform": "translateY(0)" }, { "transform": "translateY(-7px)" }] },
        { "target": "#brow-right", "duration": 250, "fill": "forwards",
          "keyframes": [{ "transform": "translateY(0)" }, { "transform": "translateY(-7px)" }] },
        { "target": "#eyes", "duration": 250, "fill": "forwards",
          "keyframes": [{ "transform": "scale(1)" }, { "transform": "scale(1.2)" }] }
      ]
    },
    "neutral": { "reset": true, "tracks": [] }
  }
}
